{
  "version": 2,
  "builds": [
    {
      "src": "api/vercel-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/vercel-server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/web/dist/index.html"
    }
  ]
}
